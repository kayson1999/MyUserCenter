# ============================================
# MyUserCenter 环境变量配置示例
# 复制此文件为 .env 并修改对应的值
# cp .env.example .env
# ============================================

# 服务端口
PORT=4000

# JWT 密钥（请修改为随机字符串）
JWT_SECRET=please_change_this_to_a_random_string
# JWT 过期时间（支持 7d / 24h / 30m 格式）
JWT_EXPIRES_IN=7d

# 内部通信密钥（服务间调用，请修改为随机字符串）
INTERNAL_SECRET=please_change_this_to_another_random_string

# ── 数据库配置 ──

# 数据库类型：mysql 或 sqlite（默认 mysql）
DB_TYPE=mysql

# MySQL 数据库配置（DB_TYPE=mysql 时生效）
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=root
DB_NAME=usercenter

# SQLite 数据库配置（DB_TYPE=sqlite 时生效）
DB_PATH=./data/usercenter.db

# ── 日志配置 ──

# 是否输出日志到文件（true/false，默认 true）
LOG_TO_FILE=true
# 日志目录路径（相对于启动根路径）
LOG_DIR=./logs
# 日志文件名前缀（最终文件名格式: {prefix}-{date}.log）
LOG_FILE_PREFIX=usercenter
# 日志保留天数（0 表示不限制）
LOG_MAX_DAYS=1
